# Local secrets for the paper-digest harness. Copy to `.env` (gitignored) and fill in.
# Loaded by run.sh and the systemd units (EnvironmentFile).

# Semantic Scholar API key — lifts the unauthenticated rate limit so citation
# counts resolve in full instead of backfilling slowly over nightly runs.
# Request one (free, emailed after approval): https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=
